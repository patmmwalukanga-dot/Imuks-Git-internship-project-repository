{
  "name": "nextjs-project-template",
  "version": "0.1.0",
  "private": true,
  "description": "A production-minded Next.js App Router starter with MUI, styled-components, MobX, Zod, i18n, and native fetch patterns.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ignore-pattern '.next' --ignore-pattern 'node_modules'",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "prepare": "husky"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "@mui/material-nextjs": "^7.3.5",
    "@supabase/supabase-js": "^2.108.2",
    "i18next": "^25.6.3",
    "mobx": "^6.15.0",
    "mobx-persist-store": "^1.1.8",
    "mobx-react-lite": "^4.1.1",
    "next": "^16.0.10",
    "nextjs-toploader": "^3.9.17",
    "notistack": "^3.0.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.68.0",
    "react-i18next": "^16.3.5",
    "styled-components": "^6.1.19",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint/js": "^9.39.2",
    "@next/eslint-plugin-next": "16.0.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.10",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.0.15",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.0.10",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^27.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=22.0.0",
    "yarn": ">=1.22.0 <4.0.0"
  }
}
